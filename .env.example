# ─────────────────────────────────────────────────────────────────────────────
# INVARITECH FRONTEND — Environment Variables
# Copy this file to .env.local and fill in the values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only and never sent to the client.
# ─────────────────────────────────────────────────────────────────────────────


# ── Contact / Assessment API (internal backend) ───────────────────────────────
# Base URL of the api-server (invaritech-ai/contact-form-API).
# Local dev: http://localhost:3001 (if running api-server locally)
# Production: https://contact-api.invaritech.ai
API_URL=

# Shared secret sent as X-Internal-Secret header on every proxied request.
# Must match INTERNAL_SECRET on the api-server.
INTERNAL_SECRET=


# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
# Used by proxy.ts middleware to rate-limit /api/* routes (10 req/min per IP).
# Fails open — if unset or unavailable, requests are allowed through.
# Get these from https://console.upstash.com → your Redis database → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── Invoice Extractor Tool ────────────────────────────────────────────────────
# Cloud Run backend for the /tools/invoice-extractor/ tool.
# Base URL should not have a trailing slash.
INVOICE_BACKEND_BASE_URL=https://invoice-api-1003212465481.asia-southeast1.run.app
# API key issued by the invoice backend. Never expose this to the browser.
INVOICE_BACKEND_API_KEY=


# ── reCAPTCHA v3 ─────────────────────────────────────────────────────────────
# Site key (public) — used by contact form and assessment wizard.
# Get from https://www.google.com/recaptcha/admin
# The secret key lives on the api-server, not here.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=


# ── Site Metadata ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.invaritech.ai
NEXT_PUBLIC_SITE_NAME=Invaritech Visionary Launch


# ── Search Engine Verification (optional) ────────────────────────────────────
# Add the value tokens from each search console. Leave blank to skip.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_YAHOO_VERIFICATION=
